MINIO_ROOT_USER=changeme
MINIO_ROOT_PASSWORD=changeme
# Адрес MinIO для сервера, запущенного ЛОКАЛЬНО (python server.py).
# В docker-compose это значение переопределяется на minio:9000 автоматически.
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=images
# Максимальный суммарный размер бакета в байтах (0 — без ограничения).
# Пример: 1073741824 = 1 GiB
MINIO_MAX_BYTES=0
# Доля лимита (0..1), при достижении которой в лог пишутся предупреждения.
MINIO_WARN_THRESHOLD=0.8
